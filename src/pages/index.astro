          bottomRow.style.fontWeight = '700';
          bottomRow.style.fontSize = '17px';
          bottomRow.style.lineHeight = '1.05';

          topRow.append(prefix, price, setLabel, suffix);
          bannerOverlay.append(topRow, bottomRow);

