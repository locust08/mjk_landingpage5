---
import fs from 'node:fs/promises';
import path from 'node:path';

const baseDir = path.join(process.cwd(), 'public', 'reference', "home");
const head = JSON.parse(await fs.readFile(path.join(baseDir, 'head.json'), 'utf8'));
const sourceUrl = "https://www.malayajerseyking.com.my/";
const routeMap = {
  "https://www.malayajerseyking.com.my/": "/"
};
const framePath = '/reference/home/index.html';
---

<html>
  <head>
    <title>{head.title}</title>
    {head.metas?.map((meta) => <meta {...meta} />)}
    {head.links?.map((link) => <link {...link} />)}
    <style>
      html, body {
        margin: 0;
        height: 100%;
      }

      .frame-shell {
        position: relative;
        width: 100%;
        height: 100vh;
        overflow: hidden;
        background: #ffffff;
      }

      iframe {
        width: 100%;
        height: 100vh;
        border: 0;
        display: block;
        opacity: 0;
        transition: opacity 180ms ease;
      }

      .frame-shell.is-ready iframe {
        opacity: 1;
      }

      .frame-cover {
        position: absolute;
        inset: 0;
        z-index: 1;
        background:
          radial-gradient(circle at top, rgba(242, 123, 24, 0.12), transparent 44%),
          #ffffff;
        transition: opacity 180ms ease, visibility 180ms ease;
      }

      .frame-shell.is-ready .frame-cover {
        opacity: 0;
        visibility: hidden;
      }
    </style>
  </head>
  <body>
    <div class="frame-shell" id="frame-shell">
      <div class="frame-cover" aria-hidden="true"></div>
      <iframe id="page-frame" src={framePath}></iframe>
    </div>
    <script is:inline>
      const iframe = document.getElementById('page-frame');
      const frameShell = document.getElementById('frame-shell');
      const sourceUrlValue = "https://www.malayajerseyking.com.my/";
      const imageVersion = '20260421';
      const routeMapValue = {
  "https://www.malayajerseyking.com.my/": "/"
};

      const revealFrame = () => {
        frameShell?.classList.add('is-ready');
      };

      const normalizeTarget = (href) => {
        if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) {
          return null;
        }

        try {
          const resolvedUrl = new URL(href, sourceUrlValue);
          const pathname = resolvedUrl.pathname.replace(/\/+$/, '') || '/';
          return resolvedUrl.origin + pathname;
        } catch {
          return null;
        }
      };

      const localRouteForHref = (href) => {
        const normalizedTarget = normalizeTarget(href);
        if (!normalizedTarget) return null;
        return routeMapValue[normalizedTarget] || null;
      };

      const rewriteLinks = (root) => {
        root.querySelectorAll?.('a[href]').forEach((link) => {
          const localRoute = localRouteForHref(link.getAttribute('href'));
          if (!localRoute) return;

          link.setAttribute('href', localRoute);
          link.setAttribute('target', '_top');
        });
      };

      iframe?.addEventListener('load', () => {
        const iframeWindow = iframe.contentWindow;
        const iframeDocument = iframe.contentDocument;
        if (!iframeWindow || !iframeDocument) {
          revealFrame();
          return;
        }

        const headerStyle = iframeDocument.createElement('style');
        headerStyle.textContent = `
          .tatsu-header.rG .qG {
            height: 70px !important;
          }

          #form {
            opacity: 0.95 !important;
            border-radius: 20px !important;
            overflow: hidden !important;
          }

          @media only screen and (max-width: 767px) {
            .tatsu-header.rG .qG {
              height: 72px !important;
            }
          }
        `;
        iframeDocument.head?.appendChild(headerStyle);

        const promoBanner = iframeDocument.querySelector(
          'img[src*="rm19-90--2-"], img[data-src*="rm19-90--2-"]'
        );
        if (promoBanner instanceof iframeWindow.HTMLImageElement) {
          const bannerShell = promoBanner.closest('.tatsu-single-image-inner');
          if (bannerShell instanceof iframeWindow.HTMLElement) {
            bannerShell.style.position = 'relative';
          }

          promoBanner.style.visibility = 'hidden';
          promoBanner.setAttribute('aria-hidden', 'true');

          const bannerOverlay = iframeDocument.createElement('div');
          bannerOverlay.setAttribute(
            'aria-label',
            'Harga Serendah RM22.90/SET Sahaja Dapat Baju Full Sublimation + 3D Medal'
          );
          bannerOverlay.style.position = 'absolute';
          bannerOverlay.style.inset = '0';
          bannerOverlay.style.display = 'flex';
          bannerOverlay.style.flexDirection = 'column';
          bannerOverlay.style.alignItems = 'center';
