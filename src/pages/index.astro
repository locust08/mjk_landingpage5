          }

          const customerGrid = customerSection.querySelector('.people-grid');
          const customerPrevButton = customerSection.querySelector('.carousel-arrow.is-left');
          const customerNextButton = customerSection.querySelector('.carousel-arrow.is-right');

          if (
            customerGrid instanceof iframeWindow.HTMLElement &&
            customerPrevButton instanceof iframeWindow.HTMLButtonElement &&
            customerNextButton instanceof iframeWindow.HTMLButtonElement
          ) {
            const slotClasses = [
              'slot-outer-left is-outer',
              'slot-inner-left is-inner',
              'slot-center is-center',
              'slot-inner-right is-inner',
              'slot-outer-right is-outer',
            ];
            const slotOffsets = [-2, -1, 0, 1, 2];
            let activeCustomerIndex = 0;

            const wrapCustomerIndex = (index) =>
              (index + customerShowcaseItems.length) % customerShowcaseItems.length;

            const renderCustomerShowcase = () => {
              customerGrid.innerHTML = slotOffsets
                .map((offset, positionIndex) => {
                  const itemIndex = wrapCustomerIndex(activeCustomerIndex + offset);
                  const item = customerShowcaseItems[itemIndex];

                  return `
                    <article class="person-card ${slotClasses[positionIndex]}" data-position-index="${positionIndex}" data-product-index="${itemIndex}">
                      <button
                        aria-label="Lihat ${item.name}"
                        aria-pressed="${offset === 0 ? 'true' : 'false'}"
                        class="person-card-button"
                        data-source-index="${itemIndex}"
                        type="button"
                      >
                        <div class="person-image-wrap">
                          <img alt="${item.name}" class="person-image" src="${item.image}">
                        </div>
                        <p class="person-name">${item.name}</p>
                      </button>
                    </article>
                  `;
                })
                .join('');

              customerGrid.querySelectorAll('.person-card-button').forEach((button) => {
                if (!(button instanceof iframeWindow.HTMLButtonElement)) return;

                button.addEventListener('click', () => {
                  const nextIndex = Number(button.dataset.sourceIndex);
                  if (Number.isNaN(nextIndex)) return;
                  activeCustomerIndex = nextIndex;
                  renderCustomerShowcase();
                });
              });
            };

            customerPrevButton.addEventListener('click', () => {
              activeCustomerIndex = wrapCustomerIndex(activeCustomerIndex - 1);
              renderCustomerShowcase();
            });

            customerNextButton.addEventListener('click', () => {
              activeCustomerIndex = wrapCustomerIndex(activeCustomerIndex + 1);
              renderCustomerShowcase();
            });

            renderCustomerShowcase();
          }
        }

        const customerGalleryImages = [
          { match: 'polis.png', src: '/images/6.png' },
          { match: 'bomba.png', src: '/images/7.png' },
          { match: 'burger.png', src: '/images/12.png' },
          { match: 'hartalega.png', src: '/images/14.png' },
          { match: 'kbs.png', src: '/images/11.png' },
          { match: 'kkm.png', src: '/images/13.png' },
          { match: 'pos.png', src: '/images/10.png' },
          { match: 'selangor-kini.png', src: '/images/9.png' },
          { match: 'um.png', src: '/images/8.png' },
        ];

        for (const { match, src } of customerGalleryImages) {
          const image = Array.from(iframeDocument.querySelectorAll('img')).find(
            (candidate) =>
              [candidate.getAttribute('src'), candidate.getAttribute('data-src'), candidate.getAttribute('srcset'), candidate.getAttribute('data-srcset')]
                .some((value) => value?.includes(match))
          );

          if (!(image instanceof iframeWindow.HTMLImageElement)) continue;

          const localSrc = `${src}?v=${imageVersion}`;
          image.setAttribute('src', localSrc);
          image.setAttribute('data-src', localSrc);
          image.setAttribute('srcset', `${localSrc} 700w`);
          image.setAttribute('data-srcset', `${localSrc} 700w`);
          image.removeAttribute('data-webp');
        }

        rewriteLinks(iframeDocument);

        const observer = new iframeWindow.MutationObserver((mutations) => {
          for (const mutation of mutations) {
            mutation.addedNodes.forEach((node) => {
              if (node.nodeType === iframeWindow.Node.ELEMENT_NODE) {
                rewriteLinks(node);
              }
            });
          }
        });

        if (iframeDocument.documentElement) {
          observer.observe(iframeDocument.documentElement, {
            childList: true,
            subtree: true,
          });
        }

        iframeDocument.addEventListener('click', (event) => {
          const link = event.target.closest?.('a[href]');
          if (!link) return;

          const localRoute = localRouteForHref(link.getAttribute('href'));
          if (!localRoute) return;

          event.preventDefault();
          window.location.assign(localRoute);
        });

        revealFrame();
      });
